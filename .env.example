# Use local-test for the fastest local QA environment.
# Use firebase or supabase for real cloud-backed data.
VITE_DATA_BACKEND=local-test

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_AUTH_REDIRECT_URL=http://localhost:5173/
VITE_ENABLE_SUPABASE_DIAGNOSTICS=false

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_AUTH_REDIRECT_URL=http://localhost:5173/
SUPABASE_ACCESS_TOKEN=your-supabase-management-token
SUPABASE_DB_PASSWORD=your-linked-database-password

SUPABASE_BROWSER_OAUTH_E2E_CONFIRMED=false
SUPABASE_CREDENTIAL_ROTATION_VERIFIED=false

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Edge Function environment variables (configured via supabase secrets)
GEMINI_API_KEY=your-gemini-api-key
