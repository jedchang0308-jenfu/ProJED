VITE_DATA_BACKEND=firebase

# Fixed browser test URL
VITE_SUPABASE_AUTH_REDIRECT_URL=http://127.0.0.1:4173/

# Default fixed test app: Firebase test project
VITE_FIREBASE_API_KEY=replace-with-test-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-test-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace-with-test-project-id
VITE_FIREBASE_STORAGE_BUCKET=replace-with-test-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-test-sender-id
VITE_FIREBASE_APP_ID=replace-with-test-app-id
VITE_FIREBASE_MEASUREMENT_ID=replace-with-test-measurement-id
VITE_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# Optional: switch the fixed test environment to Supabase / RAG
# VITE_DATA_BACKEND=supabase
# VITE_SUPABASE_URL=https://your-test-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-test-supabase-anon-key
# SUPABASE_URL=https://your-test-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-test-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-test-supabase-service-role-key
# SUPABASE_AUTH_REDIRECT_URL=http://127.0.0.1:4173/
# GEMINI_API_KEY=your-test-gemini-api-key
