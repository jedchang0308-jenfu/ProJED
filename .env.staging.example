# Optional mode-specific overrides for Level 3 builds.
# Vite also loads .env.local. These mode-specific values must override any
# local password test settings so credentials cannot enter a preview bundle.
VITE_DATA_BACKEND=supabase
VITE_SUPABASE_URL=https://your-projed-test-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-projed-test-anon-key
VITE_SUPABASE_AUTH_MODE=oauth-google
VITE_SUPABASE_TEST_EMAIL=
VITE_SUPABASE_TEST_PASSWORD=
VITE_SUPABASE_AUTO_TEST_LOGIN=false
VITE_ENABLE_SUPABASE_DIAGNOSTICS=false

# Optional. When omitted, Supabase OAuth returns to the current preview origin.
# VITE_SUPABASE_AUTH_REDIRECT_URL=https://your-preview-url.web.app/

# Optional. Required only for Google Calendar API features, not Supabase OAuth.
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
